# Copy this file to ".env" and fill in the values. The .env file is git-ignored.

# Signs sessions + email verification tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ----------------------------------------------------------------- Email (Gmail)
# Public support address (shown on the site, receives contact-form + replies).
SUPPORT_EMAIL=andreamariecoaching@gmail.com

# SMTP account that authenticates and sends. Can differ from SUPPORT_EMAIL.
MAIL_USERNAME=your-sending-account@gmail.com

# From line recipients see. Gmail forces the address to match MAIL_USERNAME.
MAIL_SENDER=Meet You There Foundation <your-sending-account@gmail.com>

# 16-char Gmail App Password for MAIL_USERNAME (NOT the normal password).
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification).
# Leave blank to run in developer mode (verification links shown on screen).
MAIL_PASSWORD=

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true

# ----------------------------------------------------------------- Security
# Set to 1 only for local development (enables the Werkzeug debugger/reloader).
# Leave at 0 anywhere reachable by others.
FLASK_DEBUG=0
# Set to true once the site is served over HTTPS (sends cookies only over TLS).
SESSION_COOKIE_SECURE=false
# Rate-limit storage. "memory://" is fine locally; use a redis:// URL in production.
RATELIMIT_STORAGE_URI=memory://
